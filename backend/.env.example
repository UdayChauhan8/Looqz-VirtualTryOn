# ── Looqz proxy server ────────────────────────────────────────────────────────
WHITELISTED_ORIGIN=https://your-app.onrender.com
LOOQZ_API_URL=https://www.looqz.in/api/v1/public/generate-image

# ── Your Render public URL (used to construct /tmp-image/ URLs for Looqz) ────
BACKEND_URL=https://your-app.onrender.com

# ── CORS lockdown ─────────────────────────────────────────────────────────────
# Your Chrome Extension ID (from chrome://extensions/ with Developer Mode on).
# Locks CORS so only your extension can POST to this server.
# Leave empty for local development (falls back to allow_origins=["*"]).
ALLOWED_EXTENSION_ID=

# Pre-signed URL lifetime in seconds (default: 300 = 5 minutes)
# Looqz API fetches the image well inside this window.
PRESIGN_TTL_SECONDS=300
