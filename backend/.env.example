# ── Looqz proxy server ────────────────────────────────────────────────────────

# The Looqz API endpoint to proxy generate-image calls to.
LOOQZ_API_URL=https://www.looqz.in/api/v1/public/generate-image

# The Origin header to send with Looqz API calls.
# Must match the "Authorized Domain" configured for your API key on Looqz.
WHITELISTED_ORIGIN=https://www.looqz.in

# ── Your Render public URL (used to construct /tmp-image/ URLs for Looqz) ────
# MUST be set in production — the backend constructs publicly-fetchable URLs
# like https://your-app.onrender.com/tmp-image/looqz-xxx.jpg for Looqz to grab.
BACKEND_URL=https://your-app.onrender.com

# ── CORS lockdown ─────────────────────────────────────────────────────────────
# Your Chrome Extension ID (from chrome://extensions/ with Developer Mode on).
# Locks CORS so only your extension can POST to this server.
# Leave empty for local development (falls back to allow_origins=["*"]).
ALLOWED_EXTENSION_ID=
