# ── Looqz proxy server ────────────────────────────────────────────────────────
WHITELISTED_ORIGIN=https://your-app.onrender.com
LOOQZ_API_URL=https://www.looqz.in/api/v1/public/generate-image

# ── Cloudflare R2 (private image bucket) ─────────────────────────────────────
# To switch to AWS S3: remove R2_ACCOUNT_ID and the endpoint_url override in
# main.py (_make_r2_client). All other fields are identical.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=looqz-tryon-temp

# Pre-signed URL lifetime in seconds (default: 300 = 5 minutes)
# Looqz API fetches the image well inside this window.
PRESIGN_TTL_SECONDS=300
